pca_form <- as.formula(paste("attack_index_likert_pca ~", paste(ind_vars, collapse = "+")))
icw_imputed_form <- as.formula(paste("attack_index_na_icw ~", paste(ind_vars, collapse = "+")))
pca_imputed_form <- as.formula(paste("attack_index_na_pca ~", paste(ind_vars, collapse = "+")))
